{
  "name": "telegram-html",
  "version": "0.0.0",
  "private": false,
  "description": "Convert Telegram Bot API message entities into HTML, or hast, and vice versa.",
  "keywords": [
    "api",
    "ast",
    "bot",
    "entity",
    "hast",
    "html",
    "message",
    "telegram",
    "tree"
  ],
  "homepage": "https://github.com/Quadratz-Org/telegram-html",
  "bugs": "https://github.com/Quadratz-Org/telegram-html/issues",
  "license": "MIT",
  "author": "Quadratz",
  "repository": {
    "url": "git+https://github.com/Quadratz-Org/telegram-html.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run --coverage test/",
    "test:watch": "vitest --coverage",
    "check": "pnpm run fmt && pnpm run build && pnpm run lint && pnpm run test",
    "release": "bumpp --commit --push --tag"
  },
  "dependencies": {
    "@types/hast": "^3.0.4",
    "hast-util-from-html": "^2.0.3",
    "hast-util-get-attribute": "^1.0.0",
    "hast-util-select": "^6.0.4",
    "hast-util-to-html": "^9.0.5",
    "hast-util-to-text": "^4.0.2",
    "html-escaper": "^3.0.3",
    "micromark-util-sanitize-uri": "^2.0.1",
    "parse-url": "^11.1.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/html-escaper": "^3.0.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "unplugin-unused": "^0.5.7",
    "vitest": "^4.1.4"
  }
}
